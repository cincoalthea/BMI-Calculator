<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BMICalculator.MainPage"
             Title="BMI Calculator">
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">
            <Label
                Text="BMI Calculator"
                FontSize="32"
                FontAttributes="Bold"
                HorizontalOptions="Center" />

            <Label
                Text="Enter weight in kilograms and height in centimeters."
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                TextColor="{AppThemeBinding Light=Gray, Dark=LightGray}" />

            <Label Text="Weight (kg)" />
            <Entry
                x:Name="WeightEntry"
                Placeholder="e.g. 68.5"
                Keyboard="Numeric"
                ClearButtonVisibility="WhileEditing" />

            <Label Text="Height (cm)" />
            <Entry
                x:Name="HeightEntry"
                Placeholder="e.g. 172"
                Keyboard="Numeric"
                ClearButtonVisibility="WhileEditing" />

            <Button
                Text="Calculate BMI"
                Clicked="OnCalculateBmiClicked"
                Margin="0,8,0,0" />

            <Frame Padding="16" Margin="0,12,0,0">
                <VerticalStackLayout Spacing="8">
                    <Label
                        Text="Result"
                        FontAttributes="Bold"
                        FontSize="18" />
                    <Label x:Name="BmiResultLabel" Text="BMI: -" />
                    <Label x:Name="CategoryLabel" Text="Category: -" />
                    <Label x:Name="MessageLabel" TextColor="IndianRed" />
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
